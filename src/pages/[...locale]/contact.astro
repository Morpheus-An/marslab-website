---
import { i18n } from "astro:config/client";
import Base from "$layouts/Base.astro";
import i18nit from "$i18n";
import Icon from "$components/Icon.astro";

export async function getStaticPaths() {
    return i18n?.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const { locale = i18n!.defaultLocale } = Astro.params;
const t = i18nit(locale);

// Define opportunities directly in the component for better control
const contactEmail = "jianfei.yang@ntu.edu.sg";

const opportunities = [
	{
		title: "PhD Students",
		icon: "lucide:graduation-cap",
		description: "We are recruiting PhD students for the upcoming cycles. Strong backgrounds in robotics, machine learning, programming, and research are expected.",
		details: [
			"Apply to the NTU PhD program (School of Mechanical and Aerospace Engineering or School of Electrical and Electronic Engineering) and list Jianfei Yang as a potential advisor.",
			"Competitive NTU Research Scholarships are available for outstanding applicants.",
		],
		links: [
			{ text: "Email Prof. Yang", url: `mailto:${contactEmail}` }
		]
	},
	{
		title: "Postdocs",
		icon: "lucide:briefcase",
		description: "We invite applications for postdoctoral researchers. We value independent thinkers eager to lead projects and mentor students.",
		details: [
			"Please email Prof. Jianfei Yang and include your CV, a 1–2 page research statement, reference contacts, and links to representative papers/code.",
		],
		links: [
			{ text: "Email Prof. Yang", url: `mailto:${contactEmail}` }
		]
	},
	{
		title: "Master's & Undergraduate Students",
		icon: "lucide:book-open",
		description: "Master's and undergraduate students interested in research are welcome. Prior research or strong relevant coursework is preferred.",
		details: [
			"NTU students can reach out by email to discuss FYP, URECA, and research-assistant opportunities.",
		],
		links: [
			{ text: "Email the Lab", url: `mailto:${contactEmail}` }
		]
	},
	{
		title: "Visiting Researchers",
		icon: "lucide:users",
		description: "We welcome visiting students and researchers each year.",
		details: ["Collaborations work best when there is clear overlap with our research and a specific project or idea in mind. Please email us with your CV and a short note about your interests, and we'll get in touch if there's a strong match."],
		links: [
			{ text: "Email the Lab", url: `mailto:${contactEmail}` },
		]
	},
];
---

<Base title="Contact" {locale}>
	<main class="flex flex-col grow">
		<h1 class="text-3xl font-bold mb-6">Contact</h1>

		<p class="intro-text">
			We welcome students and researchers interested in robotics, embodied AI, computer vision,
			multimodal learning, world models, and human–robot interaction to join or collaborate with our lab.
			For general inquiries, please reach out by <a href={`mailto:${contactEmail}`} class="inline-link">email</a>.
		</p>

		<section class="openings">
			{opportunities.map((opp) => (
				<article class="opening">
					<div class="opening-head">
						<span class="opening-icon"><Icon name={opp.icon} size={20} /></span>
						<h2 class="opening-title">{opp.title}</h2>
					</div>

					<div class="opening-content">
						<p class="opening-desc">{opp.description}</p>

						{opp.details.length > 0 && (
							<ul class="opening-details">
								{opp.details.map((detail) => (
									<li>{detail}</li>
								))}
							</ul>
						)}

						{opp.links && opp.links.length > 0 && (
							<div class="opening-links">
								{opp.links.map((link) => (
									<a href={link.url} class="opening-link">
										<span>{link.text}</span>
										<Icon name="lucide:arrow-right" size={15} />
									</a>
								))}
							</div>
						)}
					</div>
				</article>
			))}
		</section>
	</main>
</Base>

<style>
	.intro-text {
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--secondary-color);
		max-width: 72ch;
		margin: 0 0 1rem 0;
	}

	.inline-link {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 2px;
		font-weight: 600;
		transition: opacity 0.2s ease;
	}

	.inline-link:hover {
		opacity: 0.7;
	}

	/* Editorial listing — no cards/boxes, entries separated by thin rules */
	.openings {
		display: flex;
		flex-direction: column;
	}

	.opening {
		display: grid;
		grid-template-columns: 240px 1fr;
		gap: 2.5rem;
		padding: 2rem 0;
		border-top: 1px solid var(--shadow-color);
	}

	.opening:last-child {
		border-bottom: 1px solid var(--shadow-color);
	}

	.opening-head {
		display: flex;
		align-items: flex-start;
		gap: 0.55rem;
	}

	.opening-icon {
		display: inline-flex;
		color: var(--accent);
		margin-top: 0.15rem;
		flex-shrink: 0;
	}

	.opening-icon :global(figure) {
		display: flex;
		margin: 0;
	}

	.opening-title {
		font-size: 1.25rem;
		font-weight: 600;
		line-height: 1.3;
		color: var(--primary-color);
		margin: 0;
	}

	.opening-content {
		min-width: 0;
	}

	.opening-desc {
		font-size: 1rem;
		line-height: 1.65;
		color: var(--primary-color);
		margin: 0 0 0.85rem 0;
	}

	.opening-details {
		list-style: none;
		padding: 0;
		margin: 0 0 1.1rem 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.opening-details li {
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--secondary-color);
		padding-left: 1.2rem;
		position: relative;
	}

	.opening-details li::before {
		content: "—";
		position: absolute;
		left: 0;
		color: var(--accent);
	}

	.opening-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
	}

	.opening-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--accent);
		font-weight: 600;
		font-size: 0.95rem;
		text-decoration: none;
	}

	.opening-link :global(figure) {
		display: flex;
		margin: 0;
		transition: transform 0.2s ease;
	}

	.opening-link:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.opening-link:hover :global(figure) {
		transform: translateX(3px);
	}

	/* Stack the title above the content on narrow screens */
	@media (max-width: 768px) {
		.opening {
			grid-template-columns: 1fr;
			gap: 0.85rem;
			padding: 1.6rem 0;
		}

		.intro-text {
			font-size: 1rem;
		}
	}
</style>
