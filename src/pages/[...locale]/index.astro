---
import { i18n } from "astro:config/client";
import { render, getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { Icon } from "astro-icon/components";
import Time from "$utils/time";
import Base from "$layouts/Base.astro";
import config from "$config";
import i18nit from "$i18n";
import { people } from "$data/people";

export async function getStaticPaths() {
	// Create path for each locale, omitting default locale from URL
	return i18n!.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const { locale = i18n!.defaultLocale } = Astro.params;

const t = i18nit(locale);
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Get preface content, sorted by timestamp (newest first)
const prefaces = (
	await getCollection("preface", preface => {
		const [, id] = preface.id.split("/");
		preface.id = id;
		return true;
	})
).sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

const preface = prefaces[0];
// Render preface content if available, otherwise use empty object
const { Content } = preface ? await render(preface) : ({} as any);

// Filter people with images for the grid
const peopleWithImages = people.filter(person => person.image);

// --- Hero showcase: members (center, horizontal scroll) flanked by robots (sides, vertical scroll) ---
// Robot platform photos; right column reversed for visual variety.
const robots = [
	{ name: "Unitree G1", image: "/equipment/unitree-g1.jpg" },
	{ name: "ROKAE Human.X", image: "/equipment/rokae-humanx.jpg" },
	{ name: "Galaxea R1 Lite", image: "/equipment/galaxea-r1.jpg" },
	{ name: "Franka Panda", image: "/equipment/franka-panda.jpg" },
	{ name: "UR5e", image: "/equipment/ur5e.jpg" },
	{ name: "UFactory xArm", image: "/equipment/ufactory-xarm.jpg" },
	{ name: "Sharpa Wave", image: "/equipment/sharpa-wave.jpg" },
];
const robotsLeft = robots;
const robotsRight = [...robots].reverse();

// Distribute member photos round-robin into rows; each row scrolls horizontally.
const PEOPLE_ROWS = 3;
const peopleRows: any[][] = Array.from({ length: PEOPLE_ROWS }, () => []);
peopleWithImages.forEach((person, i) => peopleRows[i % PEOPLE_ROWS].push(person));

// Lab & campus photos shown below the News section
const gallery = [
	{ image: "/gallery/lab-room.png", caption: "Our Lab" },
	{ image: "/gallery/lab-platforms.jpg", caption: "Robotic Platforms" },
	{ image: "/gallery/ntu-campus.jpg", caption: "NTU, Singapore" },
];
---

<Base title={t("navigation.home")} {locale}>
	<main class="flex flex-col gap-5 sm:gap-10 flex-grow">
		<!-- Hero showcase: robots scroll vertically on the sides, members scroll horizontally in the center -->
		<section class="showcase" aria-label="MARS Lab members and robotic platforms">
			<!-- Left: robots, vertical scroll (up) -->
			<div class="showcase-col">
				<div class="v-track v-up">
					{[...robotsLeft, ...robotsLeft].map((r) => (
						<div class="tile robot-tile"><img src={`${baseUrl}${r.image.replace(/^\//, '')}`} alt={r.name} loading="lazy" /></div>
					))}
				</div>
			</div>

			<!-- Center: members, horizontal scroll (alternating directions per row), clickable -->
			<div class="showcase-center">
				{peopleRows.map((row, i) => (
					<div class={`h-row ${i % 2 === 0 ? "h-left" : "h-right"}`}>
						{[...row, ...row].map((p) => {
							const personId = p.name.toLowerCase().replace(/[^a-z]/g, '');
							return (
								<a class="tile person-tile" href={getRelativeLocaleUrl(locale, `/people#${personId}`)} title={p.name} aria-label={p.name}>
									<img src={`${baseUrl}${p.image.replace(/^\//, '')}`} alt={p.name} loading="lazy" />
								</a>
							);
						})}
					</div>
				))}
			</div>

			<!-- Right: robots, vertical scroll (down) -->
			<div class="showcase-col">
				<div class="v-track v-down">
					{[...robotsRight, ...robotsRight].map((r) => (
						<div class="tile robot-tile"><img src={`${baseUrl}${r.image.replace(/^\//, '')}`} alt={r.name} loading="lazy" /></div>
					))}
				</div>
			</div>
		</section>

		{
			preface && (
				<section class="flex flex-col">
					<article class="markdown">
						<Content />
					</article>
					<a href={getRelativeLocaleUrl(locale, "/preface")} class="self-end my-2 text-size-sm c-secondary">
						—— {Time.date.locale(preface.data.timestamp, locale)}
					</a>
				</section>
			)
		}

		<!-- Lab & campus photo gallery -->
		<section class="gallery" aria-label="MARS Lab and NTU campus">
			{gallery.map((g) => (
				<figure class="gallery-item">
					<img src={`${baseUrl}${g.image.replace(/^\//, '')}`} alt={g.caption} loading="lazy" />
					<figcaption>{g.caption}</figcaption>
				</figure>
			))}
		</section>

	</main>
</Base>

<style>
	.showcase {
		display: flex;
		gap: 0.6rem;
		height: 360px;
		margin-top: 0.5rem;
		width: 100%;
	}

	/* Side robot columns — vertical marquee */
	.showcase-col {
		width: 140px;
		flex-shrink: 0;
		overflow: hidden;
		-webkit-mask-image: linear-gradient(to bottom, transparent, #000 12%, #000 88%, transparent);
		mask-image: linear-gradient(to bottom, transparent, #000 12%, #000 88%, transparent);
	}

	.v-track {
		display: flex;
		flex-direction: column;
		will-change: transform;
	}

	.v-up { animation: marquee-up 26s linear infinite; }
	.v-down { animation: marquee-down 30s linear infinite; }

	/* Center member area — horizontal marquee rows */
	.showcase-center {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		overflow: hidden;
		-webkit-mask-image: linear-gradient(to right, transparent, #000 6%, #000 94%, transparent);
		mask-image: linear-gradient(to right, transparent, #000 6%, #000 94%, transparent);
	}

	.h-row {
		display: flex;
		flex: 1;
		min-height: 0;
		will-change: transform;
	}

	.h-left { animation: marquee-left 55s linear infinite; }
	.h-right { animation: marquee-right 48s linear infinite; }

	/* Pause all motion on hover so members are easy to click */
	.showcase:hover .v-track,
	.showcase:hover .h-row {
		animation-play-state: paused;
	}

	.tile {
		flex-shrink: 0;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid var(--shadow-color);
		background: var(--block-color);
	}

	/* trailing margins (not flex gap) keep the duplicated track seamless at -50% */
	.robot-tile {
		width: 100%;
		aspect-ratio: 1 / 1;
		margin-bottom: 0.6rem;
	}

	.person-tile {
		height: 100%;
		aspect-ratio: 1 / 1;
		margin-right: 0.6rem;
		display: block;
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.person-tile:hover {
		transform: scale(1.05);
		box-shadow: 0 4px 12px var(--shadow-color);
		z-index: 2;
	}

	.tile img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@keyframes marquee-up {
		from { transform: translateY(0); }
		to { transform: translateY(-50%); }
	}
	@keyframes marquee-down {
		from { transform: translateY(-50%); }
		to { transform: translateY(0); }
	}
	@keyframes marquee-left {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}
	@keyframes marquee-right {
		from { transform: translateX(-50%); }
		to { transform: translateX(0); }
	}

	@media (prefers-reduced-motion: reduce) {
		.v-track, .h-row { animation: none; }
	}

	/* Lab & campus gallery */
	.gallery {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.gallery-item {
		margin: 0;
		display: flex;
		flex-direction: column;
	}

	.gallery-item img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: 10px;
		border: 1px solid var(--shadow-color);
		display: block;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.gallery-item:hover img {
		transform: translateY(-4px);
		box-shadow: 0 14px 30px rgba(0, 0, 0, 0.10);
	}

	.gallery-item figcaption {
		margin-top: 0.5rem;
		text-align: center;
		font-size: 0.85rem;
		color: var(--secondary-color);
	}

	@media (max-width: 768px) {
		.showcase {
			height: 260px;
			gap: 0.4rem;
		}
		.showcase-col {
			width: 88px;
		}
		.robot-tile { margin-bottom: 0.4rem; }
		.person-tile { margin-right: 0.4rem; }
		.showcase-center { gap: 0.4rem; }

		.gallery {
			grid-template-columns: 1fr;
			gap: 0.8rem;
		}
	}
</style>
