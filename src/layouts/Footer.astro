---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Icon from "$components/Icon.astro";
import i18nit from "$i18n";

let { locale, author, copyright } = Astro.props;

const t = i18nit(locale);
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Check if policy file exists for current locale
const information = await getCollection("information", information => {
	const [language, id] = information.id.split("/");
	information.id = id;
	return language == locale;
});

const policy = information.some(info => info.id == "policy");
---

<footer class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-8 mb-5 sm:mb-3 text-size-sm font-mono pb-5">
	<div class="flex items-center gap-1">
		{
			copyright.type != "CC0 1.0" && [
				<span>
					<Icon name="lucide:copyright" />
				</span>,
				<span>{copyright.year}</span>
			]
		}
		{
			typeof author === "string" ? (
				<span>{author}</span>
			) : !author.link ? (
				<span>{author.name}</span>
			) : (
				<a href={author.link} target="_blank" rel="noopener noreferrer">
					{author.name}
				</a>
			)
		}
		{
			policy && [
				<span>·</span>,
				<a href={getRelativeLocaleUrl(locale, "/policy")} aria-label="Policy" class="inline-flex">
					<Icon name="lucide:scale" title={t("navigation.policy")} />
				</a>
			]
		}
	</div>
	<div class="flex justify-center flex-shrink-0">
		<img src={`${baseUrl}mars_lab_logo_black.png`} alt="MARS Lab, Nanyang Technological University" class="site-logo site-logo-light h-16 sm:h-14" />
		<img src={`${baseUrl}mars_lab_logo_white.png`} alt="MARS Lab, Nanyang Technological University" class="site-logo site-logo-dark h-16 sm:h-14" />
	</div>
</footer>
